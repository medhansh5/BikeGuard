{
  "name": "bikeguard",
  "version": "1.1.0",
  "description": "AI-powered helmet detection system for road safety - Native Windows C++ implementation",
  "homepage": "https://github.com/medhansh5/Bikeguard",
  "license": "MIT",
  "dependencies": [
    {
      "name": "opencv",
      "version>=": "4.8.0",
      "features": ["world", "contrib", "dnn", "highgui", "videoio"]
    },
    {
      "name": "onnxruntime",
      "version>=": "1.16.0",
      "features": ["dml", "cuda"]
    },
    {
      "name": "directx",
      "version>=": "1.0.0",
      "features": ["dxgi", "d3d11", "d3d12"]
    },
    {
      "name": "mf",
      "version>=": "10.0.0"
    },
    {
      "name": "mfplat",
      "version>=": "10.0.0"
    },
    {
      "name": "mfuuid",
      "version>=": "10.0.0"
    },
    {
      "name": "cpr",
      "version>=": "1.10.0"
    },
    {
      "name": "nlohmann-json",
      "version>=": "3.11.0"
    }
  ],
  "builtin-baseline": "2024-01-15"
}
